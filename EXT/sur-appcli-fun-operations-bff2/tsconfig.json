{
  "include": ["src/**/*.ts"],
  "compilerOptions": {
    "experimentalDecorators": true,
    "target": "ES2019",
    "module": "commonjs",
    "lib": ["es2019"],
    "esModuleInterop": true,
    "outDir": "./app",
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true
  }
}